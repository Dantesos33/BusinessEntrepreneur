APP_NAME="Business Nexus API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────
# SUPABASE POSTGRES
# Get this from Supabase Dashboard → Connect button (top of project page)
# → "App Frameworks" or "Connection string" tab → URI.
# See the chat explanation for exactly where this moved to.
# ─────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=aws-0-xx-xxxx-x.pooler.supabase.com
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres.xxxxxxxxxxxxxxxxxxxx
DB_PASSWORD=your-supabase-db-password
DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# SESSION_DOMAIN must be null for localhost dev. In production, set
# this to your bare domain (e.g. ".yourapp.com") so the cookie is
# shared between your frontend and api subdomains if applicable.

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log

# ─────────────────────────────────────────────────────────
# CORS + SANCTUM SPA AUTH
# Must match exactly where your React app is served from (no
# trailing slash). Add more, comma-separated, for production.
# ─────────────────────────────────────────────────────────
FRONTEND_URLS=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173
SESSION_DRIVER=database

# Used by AppServiceProvider to build the password-reset email link
# back to the React app (not this API).
FRONTEND_URL=http://localhost:5173
